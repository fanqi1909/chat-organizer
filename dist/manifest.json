{
  "manifest_version": 3,
  "name": "Thread Plugin",
  "version": "0.1.0",
  "description": "Auto-threading for Claude.ai conversations",
  "permissions": [
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-BeGXF9es.js"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "resources": [
        "assets/jsx-runtime-BCZ1APbq.js",
        "assets/index.ts-CghLH_QB.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
